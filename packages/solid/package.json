{
  "name": "@djgrant/classy-solid",
  "type": "module",
  "version": "1.1.1",
  "repository": "github:djgrant/classy",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "types": "./src/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "solid": "./src/solid.js",
      "types": "./src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild src/index.js --bundle --platform=neutral --target=esnext --format=esm --external:solid-js --external:solid-js/web --outfile=dist/index.js && esbuild src/index.js --bundle --platform=neutral --target=esnext --format=cjs --external:solid-js --external:solid-js/web --outfile=dist/index.cjs",
    "test": "node --test"
  },
  "dependencies": {
    "@djgrant/classy-core": "^1.0.0"
  },
  "peerDependencies": {
    "solid-js": ">=1.9.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.9"
  }
}
